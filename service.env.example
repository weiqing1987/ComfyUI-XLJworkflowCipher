# Remote backend base URL. The plugin proxies or directly calls:
#   {XLJWORKFLOWCIPHER_API_BASE}/xljworkflowcipher/api/*
XLJWORKFLOWCIPHER_API_BASE=https://your-license-service.example.com

# Optional server-to-server proxy base URL used only by the local ComfyUI
# backend proxy. Set this when browser-facing HTTPS and local proxy routing
# should use different upstream addresses.
# XLJWORKFLOWCIPHER_PROXY_API_BASE=http://your-internal-license-service:8218

# Creator portal entry opened by the plugin UI.
XLJWORKFLOWCIPHER_PORTAL_URL=https://your-license-service.example.com/xljworkflowcipher/portal
